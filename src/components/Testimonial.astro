---
interface Props {
  body: string;
  name: string;
  role: string;
}
const { body, name, role } = Astro.props;
---
<style>
  .t-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-gray-light);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .t-stars { display: flex; gap: 2px; }
  .t-body {
    font-size: 14px;
    color: var(--color-gray);
    line-height: 1.85;
    flex: 1;
  }
  .t-footer { display: flex; align-items: center; gap: 12px; margin-top: auto; }
  .t-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--color-orange-light);
    display: flex; align-items: center; justify-content: center;
    font-weight: 700;
    color: var(--color-orange);
    font-size: 15px;
    flex-shrink: 0;
  }
  .t-name { font-weight: 700; font-size: 14px; color: var(--color-charcoal); }
  .t-role { font-size: 12px; color: var(--color-gray); }
</style>

<div class="t-card">
  <div class="t-stars">
    {[1,2,3,4,5].map(() => (
      <svg width="16" height="16" viewBox="0 0 24 24" fill="#E97132" aria-hidden="true">
        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
      </svg>
    ))}
  </div>
  <p class="t-body">「{body}」</p>
  <div class="t-footer">
    <div class="t-avatar">{name[0]}</div>
    <div>
      <p class="t-name">{name}</p>
      <p class="t-role">{role}</p>
    </div>
  </div>
</div>
