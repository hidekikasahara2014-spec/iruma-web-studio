---
interface Props {
  body: string;
  name: string;
  role: string;
}
const { body, name, role } = Astro.props;
---
<div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm flex flex-col gap-4">
  <div class="flex gap-1 text-orange-400">
    {"★★★★★".split("").map(s => <span>{s}</span>)}
  </div>
  <p class="text-gray-700 leading-relaxed text-sm">"{body}"</p>
  <div class="flex items-center gap-3 mt-auto">
    <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-900 font-bold text-sm">
      {name[0]}
    </div>
    <div>
      <p class="font-bold text-gray-800 text-sm">{name}</p>
      <p class="text-xs text-gray-500">{role}</p>
    </div>
  </div>
</div>
