---
import { site } from '../config/site';
const navLinks = [
  { href: "/", label: "ホーム" },
  { href: "/service", label: "サービス" },
  { href: "/pricing", label: "料金" },
  { href: "/samples", label: "サンプル" },
  { href: "/about", label: "会社概要" },
  { href: "/contact", label: "お問い合わせ" },
];
---
<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 font-bold text-blue-900 text-lg">
      <span class="text-2xl">🌐</span>
      <span class="hidden sm:inline">{site.name}</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(l => (
        <a href={l.href} class="text-gray-700 hover:text-blue-900 font-medium text-sm transition-colors">{l.label}</a>
      ))}
      <a href="/contact" class="bg-orange-400 text-white font-bold px-4 py-2 rounded-lg hover:bg-orange-500 transition-colors text-sm">
        無料相談
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button id="menu-btn" class="md:hidden p-2 rounded text-gray-700" aria-label="メニュー">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        <path id="icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <nav id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 pb-4">
    <div class="max-w-6xl mx-auto px-4 flex flex-col gap-1 pt-2">
      {navLinks.map(l => (
        <a href={l.href} class="py-2 text-gray-700 hover:text-blue-900 font-medium border-b border-gray-50">{l.label}</a>
      ))}
      <a href="/contact" class="mt-2 bg-orange-400 text-white font-bold px-4 py-3 rounded-lg text-center hover:bg-orange-500 transition-colors">
        無料相談を申し込む
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;
  btn.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden');
    iconOpen.classList.toggle('hidden', !open);
    iconClose.classList.toggle('hidden', open);
  });
</script>
