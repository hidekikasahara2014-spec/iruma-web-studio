---
import { site } from '../config/site';
---
<footer class="bg-gray-900 text-gray-300 mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <p class="font-bold text-white text-lg mb-2">{site.name}</p>
        <p class="text-sm text-gray-400 mb-4">{site.tagline}</p>
        <p class="text-sm">{site.address}</p>
        <p class="text-sm">TEL: {site.tel}</p>
        <p class="text-sm">{site.email}</p>
      </div>
      <div>
        <p class="font-bold text-white mb-3">ページ</p>
        <ul class="space-y-1 text-sm">
          {[
            ["/","ホーム"],["/service","サービス"],["/pricing","料金プラン"],
            ["/samples","業種別サンプル"],["/about","会社概要"],["/contact","お問い合わせ"],
            ["/privacy","プライバシーポリシー"]
          ].map(([href, label]) => (
            <li><a href={href} class="hover:text-white transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <p class="font-bold text-white mb-3">業種別サンプル</p>
        <ul class="space-y-1 text-sm">
          {[
            ["飲食店","restaurant"],["美容室","beauty-salon"],["整体・接骨院","clinic"],
            ["工務店","construction"],["自動車整備","auto-repair"],["学習塾","cram-school"],["歯科医院","dental"]
          ].map(([label, slug]) => (
            <li><a href={`/samples/${slug}`} class="hover:text-white transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-700 mt-8 pt-6 text-center text-xs text-gray-500">
      <p>© {new Date().getFullYear()} {site.name}. All rights reserved.</p>
    </div>
  </div>
</footer>
