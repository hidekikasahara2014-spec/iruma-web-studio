---
interface Props {
  name: string;
  price: string;
  period?: string;
  popular?: boolean;
  features: string[];
  cta?: string;
  ctaHref?: string;
  note?: string;
}
// 修正: TASK1 - メール相談に統一
const { name, price, period = "（税抜）", popular = false, features, cta = "無料相談を申し込む", ctaHref = "mailto:medaker.jp@gmail.com", note } = Astro.props;
---
<style>
  .pricing-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-gray-light);
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: all 0.3s;
  }
  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
  }
  .pricing-card.popular {
    border: 2px solid var(--color-orange);
    transform: scale(1.04);
  }
  .pricing-card.popular:hover {
    transform: scale(1.04) translateY(-4px);
  }
  .popular-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-orange);
    color: var(--color-white);
    font-size: 12px;
    font-weight: 700;
    padding: 4px 18px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
    font-family: var(--font-en);
    letter-spacing: 0.05em;
  }
  .p-name {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-charcoal);
    margin-bottom: 4px;
  }
  .p-price {
    font-family: var(--font-en);
    font-size: 40px;
    font-weight: 600;
    color: var(--color-charcoal);
    line-height: 1.2;
    margin-bottom: 4px;
  }
  .p-period {
    font-size: 13px;
    color: var(--color-gray);
    margin-bottom: 24px;
  }
  .p-feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--color-gray);
    padding: 6px 0;
  }
  .p-check { color: var(--color-sage); flex-shrink: 0; margin-top: 2px; }
  .p-note { font-size: 12px; color: var(--color-gray); margin-bottom: 20px; }
  .p-btn-primary {
    display: block;
    text-align: center;
    padding: 14px 24px;
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    background: var(--color-orange);
    color: var(--color-white);
    transition: all 0.25s;
  }
  .p-btn-primary:hover { background: var(--color-orange-deep); transform: translateY(-1px); }
  .p-btn-secondary {
    display: block;
    text-align: center;
    padding: 13px 24px;
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border: 1.5px solid var(--color-charcoal);
    color: var(--color-charcoal);
    transition: all 0.25s;
  }
  .p-btn-secondary:hover { background: var(--color-charcoal); color: var(--color-white); }
</style>

<div class={`pricing-card ${popular ? 'popular' : ''}`}>
  {popular && <div class="popular-badge">人気 No.1</div>}
  <p class="p-name">{name}</p>
  <p class="p-price">{price}</p>
  <p class="p-period">{period}</p>
  <div style="flex: 1; margin-bottom: 24px;">
    {features.map(f => (
      <div class="p-feature">
        <svg class="p-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12L10 17L20 7"/>
        </svg>
        <span>{f}</span>
      </div>
    ))}
  </div>
  {note && <p class="p-note">{note}</p>}
  {popular
    ? <a href={ctaHref} class="p-btn-primary">{cta}</a>
    : <a href={ctaHref} class="p-btn-secondary">{cta}</a>
  }
</div>
