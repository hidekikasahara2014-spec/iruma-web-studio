---
import MainLayout from '../layouts/MainLayout.astro';
import { industries } from '../config/site';

const faqItems = [
  { q: "制作期間はどのくらいですか？", a: "Starterプランは最短7日、Standardプランは2〜3週間、Professionalプランは1〜2ヶ月が目安です。お客様からのご素材提供が早いほど短期間で完成します。" },
  { q: "自分でも更新できますか？", a: "Professionalプランではお客様自身で更新できるCMSを標準実装します。Starter・Standardプランでは保守プランをご契約いただくことで、月に1〜3回の更新作業を代行します。" },
  { q: "ドメインやサーバーの契約はどうなりますか？", a: "ドメイン（年間約1,000〜3,000円）とサーバー（月額約500〜1,500円）は別途お客様名義でご契約いただきます。設定・移管サポートは全プランで無料対応しています。" },
  { q: "既存のホームページのリニューアルは対応できますか？", a: "はい、対応しています。既存サイトのデザイン・コンテンツを活かしながらリニューアルするプランもご相談ください。Standardプラン以上でのご対応になります。" },
  { q: "入間市以外でも依頼できますか？", a: "もちろんです。全国対応しております。オンライン（ビデオ通話）でのご相談・ヒアリングも可能です。埼玉県内は対面での訪問打ち合わせにも対応しています。" },
  { q: "個人事業主でも依頼できますか？", a: "はい、歓迎しております。むしろ個人事業主のお客様が多数いらっしゃいます。開業準備中の方や、副業からホームページが必要になった方など、お気軽にご相談ください。" },
  { q: "解約や変更は可能ですか？", a: "保守プランは月単位でご契約いただいており、1ヶ月前のご連絡でいつでも解約できます。解約手数料はありません。制作プランのキャンセルについては、進捗状況に応じてご相談ください。" },
];

const industrySvgs: Record<string, string> = {
  restaurant: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2V8C3 9 4 10 5 10V22M9 2V8C9 9 8 10 7 10M5 10V2"/><path d="M19 2C16 2 14 5 14 9C14 11 15 12 16 13L17 22M19 2V13"/></svg>`,
  "beauty-salon": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>`,
  clinic: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12H15M12 9V15M5 22V8L12 3L19 8V22M5 22H19"/></svg>`,
  construction: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21H21M5 21V10L12 5L19 10V21M9 21V14H15V21"/></svg>`,
  "auto-repair": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17H3V12L6 7H18L21 12V17H19M5 17V19H8V17M5 17H19M19 17V19H16V17"/><circle cx="7.5" cy="14" r="1.5" fill="currentColor" stroke="none"/><circle cx="16.5" cy="14" r="1.5" fill="currentColor" stroke="none"/></svg>`,
  "cram-school": `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5C4 18 5 17 6.5 17H20V3H6.5C5 3 4 4 4 5.5V19.5ZM4 19.5C4 21 5 22 6.5 22H20V20"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="16" y2="11"/></svg>`,
  dental: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22C10 22 9 18 9 14C9 12 8 10 6 10C5 10 4 9 4 7C4 4 7 2 12 2C17 2 20 4 20 7C20 9 19 10 18 10C16 10 15 12 15 14C15 18 14 22 12 22Z"/></svg>`,
};

const testimonials = [
  { body: "見積もりを依頼したら驚くほどリーズナブルで、仕上がりも想像以上。飲食店向けのサンプルを見せてもらってすぐに決めました。公開後、Googleからの問い合わせが月3〜5件増えています。", name: "田中 幸子 様", role: "飲食店オーナー（40代・入間市）" },
  { body: "以前の制作会社には高額な見積もりを出されて断念していたので半信半疑でしたが、打ち合わせから公開まで本当にスピーディーで丁寧でした。スマホ対応や検索対策も標準でやってもらえて大満足です。", name: "鈴木 美咲 様", role: "美容室オーナー（30代・所沢市）" },
  { body: "整体院を開業するにあたり、開業と同時にホームページも公開できました。AIを使っているとは思えないクオリティで、患者さんから「サイト見ました」という声が増えています。", name: "山本 雅人 様", role: "整体院院長（50代・狭山市）" },
];
---
<style>
  /* ===== SECTION LABEL ===== */
  .section-label {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 16px;
  }
  .section-label-line {
    width: 40px;
    height: 1px;
    background: var(--color-orange);
    display: block;
    flex-shrink: 0;
  }
  .section-label-text {
    font-family: var(--font-en);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-orange);
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }
  .section-title {
    font-family: var(--font-serif);
    font-size: 38px;
    font-weight: 700;
    color: var(--color-charcoal);
    line-height: 1.4;
    margin-bottom: 12px;
  }
  .section-subtitle {
    color: var(--color-gray);
    font-size: 16px;
    margin-bottom: 56px;
    max-width: 600px;
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 88vh;
    padding: 100px 80px 80px;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 60px;
    align-items: center;
    background: var(--color-cream);
    overflow: hidden;
  }
  .hero-blob {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--color-orange-light) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 0;
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    animation: fadeInUp 0.8s ease-out;
  }
  .hero-illustration {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    animation: fadeInUp 0.8s ease-out 0.2s backwards;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-orange-deep);
    letter-spacing: 0.18em;
    margin-bottom: 28px;
    padding: 8px 18px;
    background: var(--color-orange-light);
    border-radius: var(--radius-pill);
    font-family: var(--font-en);
  }
  .eyebrow::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--color-orange);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(40px, 4.8vw, 64px);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: 0.01em;
    color: var(--color-charcoal);
    margin-bottom: 28px;
  }
  .hero-title .accent {
    color: var(--color-orange);
    position: relative;
    display: inline-block;
  }
  .hero-title .accent::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    right: 0;
    height: 8px;
    background: var(--color-orange-tint);
    z-index: -1;
  }
  .hero-subtitle {
    font-size: 17px;
    color: var(--color-gray);
    line-height: 1.9;
    margin-bottom: 40px;
    max-width: 540px;
  }
  .hero-subtitle strong {
    font-weight: 600;
    color: var(--color-charcoal);
  }
  .cta-group {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    border-radius: var(--radius-pill);
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
    letter-spacing: 0.02em;
  }
  .btn-primary {
    background: var(--color-orange);
    color: var(--color-white);
    box-shadow: var(--shadow-md);
  }
  .btn-primary:hover {
    background: var(--color-orange-deep);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }
  .btn-secondary {
    background: transparent;
    color: var(--color-charcoal);
    border: 1.5px solid var(--color-charcoal);
  }
  .btn-secondary:hover {
    background: var(--color-charcoal);
    color: var(--color-white);
  }
  .btn .arrow { transition: transform 0.25s ease; }
  .btn:hover .arrow { transform: translateX(4px); }
  .hero-meta {
    display: flex;
    gap: 24px;
    font-size: 13px;
    color: var(--color-gray);
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-meta-item .check { color: var(--color-sage); }
  .deco {
    position: absolute;
    pointer-events: none;
  }
  .deco-1 {
    top: 8%; left: 5%;
    width: 32px; height: 32px;
    background: var(--color-orange);
    border-radius: 50%;
    opacity: 0.15;
    animation: float 6s ease-in-out infinite;
  }
  .deco-2 {
    bottom: 12%; right: 8%;
    width: 18px; height: 18px;
    background: var(--color-sage);
    border-radius: 50%;
    opacity: 0.3;
    animation: float 7s ease-in-out infinite 1s;
  }
  .deco-3 {
    top: 35%; right: 0;
    width: 50px; height: 50px;
    border: 2px solid var(--color-orange-tint);
    border-radius: 50%;
    animation: float 8s ease-in-out infinite 0.5s;
  }

  /* ===== PAIN CARDS ===== */
  .pain-card {
    background: var(--color-cream);
    padding: 40px 32px;
    border-radius: var(--radius-lg);
    border: 1px solid transparent;
    transition: all 0.3s;
  }
  .pain-card:hover {
    background: var(--color-white);
    border-color: var(--color-gray-light);
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
  }
  .card-icon {
    width: 56px;
    height: 56px;
    background: var(--color-orange-light);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    transition: all 0.3s;
    color: var(--color-orange);
  }
  .pain-card:hover .card-icon {
    background: var(--color-orange);
    color: var(--color-white);
  }
  .card-title {
    font-family: var(--font-serif);
    font-size: 19px;
    font-weight: 700;
    color: var(--color-charcoal);
    margin-bottom: 12px;
  }
  .card-body {
    font-size: 14px;
    color: var(--color-gray);
    line-height: 1.85;
  }

  /* ===== SOLUTION CARDS ===== */
  .solution-card {
    background: var(--color-white);
    padding: 40px 32px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-gray-light);
    transition: all 0.3s;
    position: relative;
  }
  .solution-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
  }
  .solution-num {
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 800;
    color: var(--color-orange-tint);
    line-height: 1;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .solution-sub {
    font-size: 13px;
    color: var(--color-orange);
    font-weight: 600;
    margin-bottom: 12px;
    font-family: var(--font-en);
    letter-spacing: 0.05em;
  }

  /* ===== SAMPLE CARDS ===== */
  .sample-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 32px 24px;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-gray-light);
    text-decoration: none;
    transition: all 0.3s;
    color: inherit;
  }
  .sample-card:hover {
    border-color: var(--color-orange);
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
  }
  .sample-icon {
    width: 56px;
    height: 56px;
    background: var(--color-orange-light);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    color: var(--color-orange);
    transition: all 0.3s;
  }
  .sample-card:hover .sample-icon {
    background: var(--color-orange);
    color: var(--color-white);
  }
  .sample-name {
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-charcoal);
    margin-bottom: 8px;
  }
  .sample-desc {
    font-size: 13px;
    color: var(--color-gray);
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .sample-link {
    font-size: 13px;
    color: var(--color-orange);
    font-weight: 600;
    font-family: var(--font-en);
  }

  /* ===== PRICING ===== */
  .pricing-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-gray-light);
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    transition: all 0.3s;
    position: relative;
  }
  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card);
  }
  .pricing-card.popular {
    border: 2px solid var(--color-orange);
    transform: scale(1.04);
  }
  .pricing-card.popular:hover {
    transform: scale(1.04) translateY(-4px);
  }
  .popular-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-orange);
    color: var(--color-white);
    font-size: 12px;
    font-weight: 700;
    padding: 4px 18px;
    border-radius: var(--radius-pill);
    white-space: nowrap;
    font-family: var(--font-en);
    letter-spacing: 0.05em;
  }
  .pricing-name {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-charcoal);
    margin-bottom: 4px;
  }
  .pricing-price {
    font-family: var(--font-en);
    font-size: 40px;
    font-weight: 600;
    color: var(--color-charcoal);
    line-height: 1.2;
    margin-bottom: 4px;
  }
  .pricing-period {
    font-size: 13px;
    color: var(--color-gray);
    margin-bottom: 24px;
  }
  .pricing-feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 14px;
    color: var(--color-gray);
    padding: 6px 0;
  }
  .pricing-check {
    color: var(--color-sage);
    flex-shrink: 0;
    margin-top: 2px;
  }
  .pricing-note {
    font-size: 12px;
    color: var(--color-gray);
    margin-bottom: 20px;
    margin-top: 4px;
  }
  .btn-pricing-primary {
    display: block;
    text-align: center;
    padding: 14px 24px;
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    background: var(--color-orange);
    color: var(--color-white);
    transition: all 0.25s;
  }
  .btn-pricing-primary:hover {
    background: var(--color-orange-deep);
    transform: translateY(-1px);
  }
  .btn-pricing-secondary {
    display: block;
    text-align: center;
    padding: 13px 24px;
    border-radius: var(--radius-pill);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    border: 1.5px solid var(--color-charcoal);
    color: var(--color-charcoal);
    transition: all 0.25s;
  }
  .btn-pricing-secondary:hover {
    background: var(--color-charcoal);
    color: var(--color-white);
  }

  /* ===== TESTIMONIALS ===== */
  .testimonial-card {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-gray-light);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .testimonial-body {
    font-size: 14px;
    color: var(--color-gray);
    line-height: 1.85;
    flex: 1;
  }
  .testimonial-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-orange-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: var(--color-orange);
    font-size: 15px;
    flex-shrink: 0;
  }

  /* ===== FAQ ===== */
  .faq-item {
    border-bottom: 1px solid var(--color-gray-light);
  }
  .faq-item:first-child { border-top: 1px solid var(--color-gray-light); }
  .faq-summary {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px 0;
    cursor: pointer;
    font-weight: 500;
    color: var(--color-charcoal);
    list-style: none;
    transition: color 0.2s;
  }
  .faq-summary:hover { color: var(--color-orange); }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-q {
    font-family: var(--font-en);
    font-weight: 700;
    color: var(--color-orange);
    font-size: 16px;
    flex-shrink: 0;
  }
  .faq-chevron {
    margin-left: auto;
    flex-shrink: 0;
    color: var(--color-gray);
    transition: transform 0.25s ease;
  }
  details[open] .faq-chevron { transform: rotate(180deg); }
  .faq-answer {
    padding: 0 0 20px 32px;
    font-size: 14px;
    color: var(--color-gray);
    line-height: 1.85;
  }
  .faq-a {
    font-family: var(--font-en);
    font-weight: 700;
    color: var(--color-orange);
    margin-right: 8px;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
      padding: 60px 32px 60px;
      text-align: center;
      min-height: auto;
    }
    .hero-illustration { max-width: 360px; margin: 0 auto; }
    .cta-group { justify-content: center; }
    .hero-meta { justify-content: center; }
    .section-title { font-size: 28px; }
    .hero-subtitle { margin-left: auto; margin-right: auto; }
    .section-label { justify-content: center; }
  }
  @media (max-width: 640px) {
    .hero-title { font-size: 32px; }
    .hero { padding: 48px 20px; }
  }
</style>

<MainLayout title="ホーム" description="SE × デザイナー × 生成AI で実現する、5万円からのホームページ制作。埼玉県入間市の中小企業・個人事業主を支援します。">

  <!-- ① ヒーローセクション -->
  <section class="hero">
    <div class="hero-blob" aria-hidden="true"></div>

    <div class="hero-content">
      <div class="eyebrow">SE × デザイナー × 生成AI</div>
      <h1 class="hero-title">
        地域の<span class="accent">小さな会社</span>に、<br>
        確かなホームページを。
      </h1>
      <p class="hero-subtitle">
        <strong>5万円から始められる</strong>、入間の地元密着Web制作。<br>
        安く・速く・安心の、ワンストップサービスです。
      </p>
      <div class="cta-group">
        <a href="/pricing" class="btn btn-primary">
          料金プランを見る
          <span class="arrow">→</span>
        </a>
        <a href="/samples" class="btn btn-secondary">
          サンプルを見る
        </a>
      </div>
      <div class="hero-meta">
        <div class="hero-meta-item">
          <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12L10 17L20 7"/></svg>
          無料相談・お見積もり
        </div>
        <div class="hero-meta-item">
          <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12L10 17L20 7"/></svg>
          最短7日で公開
        </div>
        <div class="hero-meta-item">
          <svg class="check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12L10 17L20 7"/></svg>
          すべて税抜価格
        </div>
      </div>
    </div>

