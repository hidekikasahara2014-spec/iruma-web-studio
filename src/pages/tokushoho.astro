---
import MainLayout from '../layouts/MainLayout.astro';
import { site } from '../config/site';
---
<MainLayout title="特定商取引法に基づく表記" description="特定商取引法に基づく表記ページです。">

  <div style="background: var(--color-charcoal); color: var(--color-cream); padding: 60px 80px; text-align: center;">
    <h1 style="font-family: var(--font-serif); font-size: 36px; font-weight: 700;">特定商取引法に基づく表記</h1>
  </div>

  <section style="padding: 80px; background: var(--color-white);">
    <div style="max-width: 760px; margin: 0 auto; font-size: 15px; line-height: 1.9; color: var(--color-gray);">

      <table style="width: 100%; border-collapse: collapse; font-size: 15px;">
        {[
          ["事業者名", "いるまウェブ製作所"],
          ["所在地", site.address],
          ["電話番号", site.tel],
          ["メールアドレス", site.email],
          ["業務内容", "ホームページ制作・Webデザイン"],
          ["料金", "サービスページ記載の通り"],
          ["支払方法・時期", "受注後に別途ご案内いたします"],
          ["サービス提供時期", "契約締結後、別途協議の上決定いたします"],
        ].map(([label, value]) => (
          <tr style="border-bottom: 1px solid var(--color-gray-light);">
            <th style="padding: 20px 24px 20px 0; font-family: var(--font-serif); font-weight: 700; color: var(--color-charcoal); white-space: nowrap; vertical-align: top; width: 200px;">{label}</th>
            <td style="padding: 20px 0; color: var(--color-gray);">
              {label === "電話番号"
                ? <a href={`tel:${site.tel.replace(/-/g, '')}`} style="color: var(--color-orange); text-decoration: none;">{value}</a>
                : value
              }
            </td>
          </tr>
        ))}
      </table>

      <p style="margin-top: 48px; font-size: 12px; color: var(--color-gray);">※ 電話でのお問い合わせは平日 10:00〜18:00 にて受け付けております。</p>
    </div>
  </section>

</MainLayout>
