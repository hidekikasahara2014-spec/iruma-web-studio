---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="送信完了 | いるまウェブ製作所" description="お問い合わせを受け付けました。">

  <section style="background: var(--color-cream); min-height: 70vh; display: flex; align-items: center; justify-content: center; padding: 80px 24px;">
    <div style="max-width: 560px; margin: 0 auto; text-align: center;">
      <div style="width: 88px; height: 88px; background: var(--color-orange-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 32px; color: var(--color-orange);">
        <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12L10 17L20 7"/>
        </svg>
      </div>
      <h1 style="font-family: var(--font-serif); font-size: clamp(24px, 3vw, 36px); font-weight: 700; color: var(--color-charcoal); margin-bottom: 20px; line-height: 1.4;">
        お問い合わせ<br>ありがとうございます
      </h1>
      <p style="font-size: 15px; color: var(--color-gray); line-height: 1.9; margin-bottom: 48px;">
        この度はお問い合わせいただき、誠にありがとうございます。<br>
        内容を確認の上、担当者より2営業日以内にご連絡いたします。<br>
        しばらくお待ちください。
      </p>
      <a href="/" style="display: inline-flex; align-items: center; gap: 8px; background: var(--color-orange); color: var(--color-white); font-weight: 700; padding: 16px 40px; border-radius: var(--radius-pill); text-decoration: none; font-size: 15px; box-shadow: var(--shadow-md); transition: all 0.25s;" onmouseover="this.style.background='var(--color-orange-deep)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='var(--color-orange)';this.style.transform='none'">
        トップページへ戻る
      </a>
    </div>
  </section>

</MainLayout>
