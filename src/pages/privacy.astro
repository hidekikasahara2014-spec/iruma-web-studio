---
import MainLayout from '../layouts/MainLayout.astro';
import { site } from '../config/site';
---
<MainLayout title="プライバシーポリシー" description="個人情報の取り扱いに関するプライバシーポリシーです。">

  <div style="background: var(--color-charcoal); color: var(--color-cream); padding: 60px 80px; text-align: center;">
    <h1 style="font-family: var(--font-serif); font-size: 36px; font-weight: 700;">プライバシーポリシー</h1>
  </div>

  <section style="padding: 80px; background: var(--color-white);">
    <div style="max-width: 760px; margin: 0 auto; font-size: 15px; line-height: 1.9; color: var(--color-gray);">
      <p style="color: var(--color-gray); margin-bottom: 40px; font-size: 13px;">最終更新日: 2024年○月○日（後日差し替え）</p>

      {[
        { num: "1", title: "個人情報の取得", body: `${site.name}（以下「当社」）は、お問い合わせ・サービス提供にあたり、お名前・メールアドレス・電話番号等の個人情報を取得することがあります。` },
        { num: "2", title: "個人情報の利用目的", items: ["お問い合わせ・ご相談への回答","サービス提供・契約の履行","請求書・領収書等の発行","重要なお知らせの送付"] },
        { num: "3", title: "第三者への提供", body: "当社は、法令に基づく場合を除き、お客様の同意なく第三者に個人情報を提供しません。" },
        { num: "4", title: "安全管理", body: "個人情報の漏えい・滅失・毀損を防ぐため、適切なセキュリティ対策を実施します。" },
        { num: "5", title: "開示・訂正・削除", body: "ご本人からの個人情報の開示・訂正・削除のご要請には、合理的な期間内に対応します。" },
        { num: "6", title: "クッキー（Cookie）について", body: "本サイトではGoogle Analytics等の解析ツールを使用しており、クッキーを利用する場合があります。クッキーの収集を望まない場合はブラウザの設定で無効化できます。" },
        { num: "7", title: "AIツールの利用について", body: "当社はサービス提供にあたり生成AIツールを使用していますが、お客様からご提供いただいた個人情報・機密情報はAIの学習データとして使用されない設定で運用します。" },
        { num: "8", title: "お問い合わせ窓口", body: `個人情報の取り扱いに関するお問い合わせは以下までご連絡ください。\n${site.name} / Email: ${site.email}` },
      ].map(({ num, title, body, items }) => (
        <div style="margin-bottom: 32px;">
          <h2 style="font-family: var(--font-serif); font-size: 18px; font-weight: 700; color: var(--color-charcoal); margin-bottom: 12px; display: flex; align-items: center; gap: 12px;">
            <span style="font-family: var(--font-en); font-size: 12px; font-weight: 700; color: var(--color-orange); background: var(--color-orange-light); padding: 4px 10px; border-radius: var(--radius-pill);">{num}</span>
            {title}
          </h2>
          {body && <p style="white-space: pre-line;">{body}</p>}
          {items && (
            <ul style="padding-left: 20px; margin-top: 8px;">
              {items.map(item => <li style="padding: 4px 0;">{item}</li>)}
            </ul>
          )}
        </div>
      ))}

      <p style="margin-top: 48px; font-size: 12px; color: var(--color-gray);">※ このプライバシーポリシーは予告なく変更される場合があります。</p>
    </div>
  </section>

</MainLayout>
