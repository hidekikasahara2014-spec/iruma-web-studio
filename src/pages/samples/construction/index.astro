---
import SampleLayout from '../../../layouts/SampleLayout.astro';
---
<SampleLayout title="武蔵野工務店 | 入間市の工務店・リフォーム" industry="construction">

  <!-- ヒーロー -->
  <section class="bg-stone-900 text-white py-24 px-4 relative overflow-hidden">
    <!-- 修正: TASK6 - AI生成テーマ画像を追加 -->
    <img src="/images/samples/sample-construction.jpg" width="1200" height="600" alt="武蔵野工務店 施工イメージ" class="absolute inset-0 w-full h-full object-cover opacity-25" />
    <div class="max-w-4xl mx-auto relative z-10">
      <p class="text-orange-300 text-sm mb-3 tracking-wider">創業40年 / 地元密着</p>
      <h1 class="text-4xl md:text-6xl font-black mb-4">武蔵野工務店</h1>
      <p class="text-2xl text-stone-200 mb-6">100年住める家を、地元で。</p>
      <p class="text-stone-300 leading-relaxed mb-8 max-w-lg">入間市・所沢市・狭山市を中心に、新築・リフォーム・増改築を手がける地元の工務店です。職人の技と最新技術で、お客様の夢の家を実現します。</p>
      <div class="flex flex-wrap gap-4">
        <a href="#contact" class="bg-orange-500 text-white font-black px-8 py-4 rounded-lg hover:bg-orange-400 transition-colors">無料見積もり相談</a>
        <a href="#works" class="border-2 border-white text-white font-bold px-8 py-4 rounded-lg hover:bg-white hover:text-stone-900 transition-colors">施工事例を見る</a>
      </div>
    </div>
  </section>

  <!-- 強み -->
  <section class="py-14 px-4 bg-amber-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-center text-stone-800 mb-10">武蔵野工務店の強み</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`, title: "自社施工・直接対応", desc: "下請けに出さず、自社の職人が責任を持って施工。中間マージンがない分、コストを抑えられます。" },
          { icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`, title: "創業40年の実績", desc: "地元で40年以上の実績。リフォームから新築まで、あらゆる住宅工事に対応しています。" },
          { icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`, title: "10年保証・アフター対応", desc: "施工後も地元の業者として長くお付き合い。困った時にすぐ駆けつけます。" },
        ].map(({ icon, title, desc }) => (
          <div class="bg-white rounded-xl p-6 border border-amber-200 shadow-sm text-center">
            <div class="flex justify-center mb-4 text-orange-600" set:html={icon}></div>
            <h3 class="font-black text-stone-800 mb-2">{title}</h3>
            <p class="text-sm text-stone-600">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 施工事例 -->
  <section id="works" class="py-14 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-center text-stone-800 mb-10">施工事例</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { title: "戸建て新築工事", loc: "入間市", img: "/images/samples/Gemini_Generated_Image_u4pl25u4pl25u4pl.png", desc: "4LDK木造2階建て。自然素材にこだわった、家族の温もりあふれる家。" },
          { title: "キッチン・浴室リフォーム", loc: "所沢市", img: "https://placehold.co/600x350/7a6248/ffffff?text=Renovation", desc: "築30年のお宅をフルリノベーション。使い勝手を大幅に改善しました。" },
          { title: "外壁塗装・屋根工事", loc: "狭山市", img: "https://placehold.co/600x350/8a7258/ffffff?text=Exterior+Painting", desc: "雨漏り修繕と外壁塗装を同時施工。耐久性の高い塗料で15年保証。" },
          { title: "2世帯住宅へのリフォーム", loc: "入間市", img: "https://placehold.co/600x350/9a8268/ffffff?text=Multi-gen+Remodel", desc: "親世帯・子世帯の動線を分けた、完全分離型の2世帯住宅に改築。" },
        ].map(({ title, loc, img, desc }) => (
          <div class="rounded-xl overflow-hidden border border-stone-200 shadow-sm">
            <img src={img} alt={title} width="600" height="350" class="w-full h-44 object-cover" loading="lazy" decoding="async" />
            <div class="p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="bg-orange-100 text-orange-700 text-xs px-2 py-0.5 rounded">{loc}</span>
                <h3 class="font-bold text-stone-800">{title}</h3>
              </div>
              <p class="text-sm text-stone-600">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- リフォームメニュー -->
  <section class="py-14 px-4 bg-stone-100">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-center text-stone-800 mb-8">工事・リフォームメニュー</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {["新築工事","増改築","外壁塗装","屋根工事","水回りリフォーム","内装リフォーム","バリアフリー化","耐震補強"].map(m => (
          <div class="bg-white rounded-lg p-4 text-center border border-stone-200 text-sm font-bold text-stone-700">
            {m}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 見積もりCTA -->
  <section id="contact" class="py-14 px-4 bg-stone-900 text-white text-center">
    <div class="max-w-xl mx-auto">
      <h2 class="text-2xl font-black mb-4">まずは無料見積もり相談から</h2>
      <p class="text-stone-300 mb-8 text-sm">現地調査・お見積もりは完全無料。お気軽にご相談ください。</p>
      <div class="space-y-3">
        <a href="tel:04-0000-0002" class="flex items-center justify-center gap-2 bg-orange-500 text-white font-bold py-4 rounded-lg hover:bg-orange-400 transition-colors text-lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .11h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          04-0000-0002
        </a>
        <button onclick="return false;" class="w-full flex items-center justify-center gap-2 border-2 border-white text-white font-bold py-4 rounded-lg hover:bg-white hover:text-stone-900 transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          フォームから相談（サンプル）
        </button>
      </div>
    </div>
  </section>

</SampleLayout>
