---
import SampleLayout from '../../../layouts/SampleLayout.astro';
---
<SampleLayout title="お食事処 さくら | 入間市の和食居酒屋" industry="restaurant">

  <!-- ヒーロー -->
  <section class="relative bg-green-950 text-white py-24 px-4 text-center overflow-hidden">
    <div class="absolute inset-0 opacity-30" style="background-image: url('https://placehold.co/1200x600/1a3a2a/ffffff?text=料理写真'); background-size: cover; background-position: center;"></div>
    <div class="relative z-10">
      <p class="text-yellow-300 text-sm tracking-widest mb-4">入間市豊岡 / 創業1985年</p>
      <h1 class="text-4xl md:text-6xl font-black mb-4" style="font-family: 'Noto Serif JP', serif;">お食事処 さくら</h1>
      <p class="text-xl text-green-100 mb-8">地元の旬を、心を込めて。</p>
      <a href="#reserve" class="bg-yellow-500 text-gray-900 font-black px-8 py-4 rounded-lg hover:bg-yellow-400 transition-colors text-lg">
        ご予約・お問い合わせ
      </a>
    </div>
  </section>

  <!-- こだわり -->
  <section class="py-14 px-4 bg-stone-50">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl font-black text-stone-800 mb-6">食材へのこだわり</h2>
      <p class="text-stone-600 leading-loose mb-8">地元農家から仕入れた旬の野菜と、毎朝豊洲から届く新鮮な海の幸。素材の味を活かした調理で、お客様に本物の旨さをお届けします。</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`, label: "地元野菜", desc: "入間市内の契約農家から直送" },
          { icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 12c.94-3.46 4.94-6 8.5-6 3.56 0 6.06 2.54 7 6-.94 3.46-3.44 6-7 6s-7.56-2.54-8.5-6z"/><circle cx="17" cy="12" r="1"/><path d="M6.5 12 2 7.5v9L6.5 12z"/></svg>`, label: "新鮮鮮魚", desc: "毎朝豊洲市場から仕入れ" },
          { icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 0 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>`, label: "地酒", desc: "埼玉県産の日本酒を厳選" },
        ].map(({ icon, label, desc }) => (
          <div class="bg-white rounded-xl p-6 border border-stone-200 shadow-sm">
            <div class="flex justify-center mb-3 text-green-700" set:html={icon}></div>
            <p class="font-bold text-stone-800 mb-1">{label}</p>
            <p class="text-sm text-stone-500">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- メニュー -->
  <section class="py-14 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-center text-stone-800 mb-8">おすすめメニュー</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { name: "さくら御膳", price: "1,980円", img: "https://placehold.co/400x250/8fbc8f/ffffff?text=さくら御膳", desc: "本日の焼き魚・小鉢3種・ご飯・お吸い物・香の物" },
          { name: "刺身盛り合わせ（3〜4人前）", price: "3,800円", img: "https://placehold.co/400x250/6aaa6a/ffffff?text=刺身盛り合わせ", desc: "本日の鮮魚5〜6種類の盛り合わせ" },
          { name: "旬野菜の天ぷら", price: "780円", img: "https://placehold.co/400x250/5a9a5a/ffffff?text=天ぷら", desc: "地元農家の旬野菜を使ったサクサク天ぷら" },
          { name: "炭火焼き鳥（5本）", price: "680円", img: "https://placehold.co/400x250/4a8a4a/ffffff?text=焼き鳥", desc: "秘伝のタレで丁寧に焼き上げた一品" },
        ].map(({ name, price, img, desc }) => (
          <div class="flex gap-4 border border-stone-200 rounded-xl overflow-hidden">
            <img src={img} alt={name} class="w-32 h-28 object-cover flex-shrink-0" />
            <div class="p-4">
              <p class="font-bold text-stone-800 mb-1">{name}</p>
              <p class="text-green-700 font-bold mb-2">{price}</p>
              <p class="text-xs text-stone-500">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 店舗情報 -->
  <section class="py-14 px-4 bg-stone-50">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-center text-stone-800 mb-8">店舗情報・アクセス</h2>
      <div class="bg-white rounded-xl p-6 border border-stone-200 shadow-sm mb-6">
        <table class="w-full text-sm">
          <tbody>
            {[
              ["住所", "埼玉県入間市豊岡 1-2-3"],
              ["電話", "04-0000-0000"],
              ["営業時間", "11:30〜14:00 / 17:00〜22:00（L.O. 21:30）"],
              ["定休日", "毎週月曜日・第3火曜日"],
              ["席数", "カウンター8席・テーブル24席・個室あり"],
              ["駐車場", "店舗前に10台"],
            ].map(([label, value]) => (
              <tr class="border-b border-stone-100">
                <th class="py-3 pr-4 text-left font-bold text-stone-500 w-24">{label}</th>
                <td class="py-3 text-stone-700">{value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <!-- マップ -->
      <div class="bg-stone-200 h-48 rounded-xl flex items-center justify-center gap-2 text-stone-500 text-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        Googleマップ埋め込み予定
      </div>
    </div>
  </section>

  <!-- お客様の声 -->
  <section class="py-14 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-center text-stone-800 mb-8">お客様の声</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {[
          { body: "地元でこんなに美味しい和食が食べられるとは！刺身の鮮度が抜群です。", name: "S.K. 様", label: "40代・入間市" },
          { body: "個室があるので接待にも使えます。料理のクオリティが高くて毎回大満足。", name: "T.M. 様", label: "50代・所沢市" },
          { body: "地元野菜の天ぷらが絶品。季節ごとにメニューが変わるので何度来ても楽しい。", name: "A.N. 様", label: "30代・狭山市" },
        ].map(({ body, name, label }) => (
          <div class="bg-stone-50 rounded-xl p-5 border border-stone-200">
            <div class="flex gap-0.5 text-yellow-400 mb-3">{'★★★★★'.split('').map(s => <span>{s}</span>)}</div>
            <p class="text-sm text-stone-700 mb-3">「{body}」</p>
            <p class="text-xs font-bold text-stone-500">{name} ({label})</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 予約フォーム -->
  <section id="reserve" class="py-14 px-4 bg-green-950 text-white">
    <div class="max-w-xl mx-auto">
      <h2 class="text-2xl font-black text-center mb-8">ご予約・お問い合わせ</h2>
      <form class="space-y-4" onsubmit="return false;">
        <input type="text" placeholder="お名前 *" class="w-full bg-white/10 border border-white/20 text-white placeholder-white/50 rounded-lg px-4 py-3 text-sm focus:outline-none" />
        <input type="tel" placeholder="電話番号 *" class="w-full bg-white/10 border border-white/20 text-white placeholder-white/50 rounded-lg px-4 py-3 text-sm focus:outline-none" />
        <input type="text" placeholder="ご希望日時" class="w-full bg-white/10 border border-white/20 text-white placeholder-white/50 rounded-lg px-4 py-3 text-sm focus:outline-none" />
        <input type="number" placeholder="人数" class="w-full bg-white/10 border border-white/20 text-white placeholder-white/50 rounded-lg px-4 py-3 text-sm focus:outline-none" />
        <textarea placeholder="ご要望・アレルギー等" rows="3" class="w-full bg-white/10 border border-white/20 text-white placeholder-white/50 rounded-lg px-4 py-3 text-sm focus:outline-none resize-none"></textarea>
        <button type="submit" class="w-full bg-yellow-500 text-gray-900 font-black py-4 rounded-lg hover:bg-yellow-400 transition-colors">
          送信する（サンプル）
        </button>
      </form>
    </div>
  </section>

</SampleLayout>
