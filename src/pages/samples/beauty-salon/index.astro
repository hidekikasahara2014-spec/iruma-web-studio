---
import SampleLayout from '../../../layouts/SampleLayout.astro';
---
<SampleLayout title="Hair Salon LUMIÈRE | 入間市の美容室" industry="beauty-salon">

  <style>
    .lumiere-accent { color: #c8a2c8; }
    .lumiere-bg { background-color: #fdf6f0; }
  </style>

  <!-- ヒーロー -->
  <section class="bg-gray-900 text-white py-28 px-4 text-center relative overflow-hidden">
    <!-- 修正: TASK6 - AI生成テーマ画像を追加 -->
    <img src="/images/samples/sample-beauty-salon.jpg" width="1200" height="600" alt="Hair Salon LUMIÈRE イメージ" class="absolute inset-0 w-full h-full object-cover opacity-20" />
    <div class="relative z-10">
      <p class="text-pink-300 tracking-[0.4em] text-xs uppercase mb-4">Hair Salon</p>
      <h1 class="text-5xl md:text-7xl font-black mb-3 tracking-widest">LUMIÈRE</h1>
      <p class="text-gray-300 text-lg mb-8">入間市駅から徒歩3分。あなたをもっと輝かせる場所。</p>
      <a href="#booking" class="bg-pink-400 text-white font-bold px-10 py-4 rounded-full hover:bg-pink-500 transition-colors text-lg">
        ご予約はこちら
      </a>
    </div>
  </section>

  <!-- スタイリスト -->
  <section class="py-16 px-4 lumiere-bg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-center text-gray-800 mb-10">スタイリスト紹介</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {[
          { name: "YUKI", role: "代表 / トップスタイリスト", exp: "経験15年", speciality: "カラー・パーマ・ブリーチ", img: "https://placehold.co/200x200/e8c8e8/4a2a4a?text=YUKI" },
          { name: "HANA", role: "スタイリスト", exp: "経験8年", speciality: "カット・縮毛矯正・トリートメント", img: "https://placehold.co/200x200/f8d8f8/4a2a4a?text=HANA" },
        ].map(({ name, role, exp, speciality, img }) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm flex gap-5 border border-pink-100">
            <img src={img} alt={name} class="w-24 h-24 rounded-full object-cover flex-shrink-0" />
            <div>
              <p class="text-xs text-pink-400 tracking-widest uppercase mb-1">{role}</p>
              <h3 class="text-2xl font-black text-gray-800 mb-1">{name}</h3>
              <p class="text-xs text-gray-500 mb-2">{exp}</p>
              <p class="text-sm text-gray-600">得意: {speciality}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- メニュー・料金 -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-center text-gray-800 mb-10">メニュー・料金</h2>
      <div class="space-y-6">
        {[
          { category: "カット", items: [["カット（シャンプーブロー込）", "¥5,500"], ["メンズカット", "¥4,400"]] },
          { category: "カラー", items: [["フルカラー", "¥8,800〜"], ["リタッチ", "¥6,600〜"], ["ハイライト", "¥11,000〜"]] },
          { category: "パーマ・矯正", items: [["デジタルパーマ", "¥15,000〜"], ["縮毛矯正", "¥18,000〜"]] },
          { category: "トリートメント", items: [["システムトリートメント", "¥3,300〜"], ["TOKIO インカラミ", "¥5,500〜"]] },
        ].map(({ category, items }) => (
          <div>
            <h3 class="font-bold text-gray-700 mb-3 border-b border-pink-100 pb-2">{category}</h3>
            <div class="space-y-2">
              {items.map(([name, price]) => (
                <div class="flex justify-between text-sm py-1">
                  <span class="text-gray-700">{name}</span>
                  <span class="font-bold text-gray-800">{price}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
      <p class="text-xs text-gray-400 mt-6">※ すべて税込価格。髪の長さ・状態により料金が変わる場合があります。</p>
    </div>
  </section>

  <!-- ギャラリー -->
  <section class="py-16 px-4 lumiere-bg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-center text-gray-800 mb-8">スタイルギャラリー</h2>
      <div class="grid grid-cols-3 md:grid-cols-4 gap-2">
        {Array.from({length: 8}, (_, i) => (
          <img src={`https://placehold.co/300x300/e8c8e8/${40+i*10}204a?text=Style${i+1}`} alt={`スタイル${i+1}`} class="aspect-square object-cover rounded-lg" />
        ))}
      </div>
    </div>
  </section>

  <!-- 予約 -->
  <section id="booking" class="py-16 px-4 bg-gray-900 text-white">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="text-2xl font-black mb-4">ご予約</h2>
      <p class="text-gray-400 mb-8">お電話またはフォームからご予約ください。</p>
      <div class="flex flex-col gap-4 mb-8">
        <a href="tel:04-0000-0000" class="bg-pink-400 text-white font-bold py-4 rounded-full hover:bg-pink-500 transition-colors text-lg flex items-center justify-center gap-2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .11h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          04-0000-0000（電話予約）
        </a>
        <a href="#" class="bg-green-500 text-white font-bold py-4 rounded-full hover:bg-green-600 transition-colors text-lg flex items-center justify-center gap-2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          LINEで予約
        </a>
      </div>
      <p class="text-gray-500 text-sm">営業時間: 火〜土 10:00〜19:00 | 日 10:00〜17:00 | 月曜定休</p>
    </div>
  </section>

</SampleLayout>
