---
import MainLayout from '../layouts/MainLayout.astro';
import { site } from '../config/site';

const members = [
  {
    icon: "🎨",
    role: "代表 / アートディレクター",
    tags: ["デザイン歴35年", "コンクール入賞多数", "Adobe Creative Suite", "ブランドデザイン"],
    bio: "幼少期から培った芸術センスと35年のデザイン経験を持つ。コンクール入賞多数の実績を誇り、いるまウェブ製作所のビジュアルクオリティを支える。",
  },
  {
    icon: "💼",
    role: "営業責任者 / DX推進アドバイザー",
    tags: ["IT業界経歴24年", "DX推進", "Web制作", "プロジェクトマネジメント", "顧客折衝"],
    bio: "IT企業で24年にわたりシステム開発・営業・プロジェクト管理を経験。DXとWeb制作の両面から、お客様のビジネス課題に最適な提案を行う。",
  },
  {
    icon: "🛡️",
    role: "テクニカルディレクター / セキュリティ専門家",
    tags: ["IT業界35年", "ネットワークスペシャリスト", "セキュリティ対策", "Webシステム開発", "複数資格保有"],
    bio: "IT業界35年のベテランエンジニア。ネットワークスペシャリスト資格をはじめ複数の国家資格を保有。セキュリティ面の盤石な体制でお客様の大切な情報を守る。",
  },
  {
    icon: "✏️",
    role: "チーフデザイナー",
    tags: ["4歳から絵画教室", "コンクール入賞20回超", "Adobe Photoshop", "Adobe Illustrator", "Blender（3D）", "Webデザイン"],
    bio: "4歳から絵画を学び、コンクール入賞20回超の実績を持つ若きデザイナー。PhotoshopやIllustratorに加え3DソフトBlenderも使いこなし、重厚感ある世界観のデザインを得意とする。",
  },
];

const companyRows: [string, string][] = [
  ["屋号", "いるまウェブ製作所"],
  ["所在地", site.address],
  ["電話番号", site.tel],
  ["営業時間", "平日 10:00〜18:00"],
  ["定休日", "土・日・祝日（緊急時対応可）"],
  ["対応エリア", "全国対応（オンライン打ち合わせ可）"],
];
---
<style>
  .page-hero { background: var(--color-charcoal); color: var(--color-cream); padding: 80px 80px 72px; position: relative; overflow: hidden; }
  .page-hero::after { content: ''; position: absolute; top: -60px; right: -60px; width: 300px; height: 300px; background: radial-gradient(circle, var(--color-orange-tint) 0%, transparent 70%); border-radius: 50%; opacity: 0.15; pointer-events: none; }
  .page-hero-label { font-family: var(--font-en); font-size: 12px; font-weight: 600; color: var(--color-orange); letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 16px; display: flex; align-items: center; gap: 12px; }
  .page-hero-label::before { content: ''; width: 32px; height: 1px; background: var(--color-orange); }
  .page-hero h1 { font-family: var(--font-serif); font-size: clamp(28px, 3.5vw, 48px); font-weight: 700; margin-bottom: 12px; color: var(--color-cream); }
  .page-hero p { font-size: 16px; color: var(--color-gray-light); }

  .section-label { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .section-label-line { width: 40px; height: 1px; background: var(--color-orange); flex-shrink: 0; }
  .section-label-text { font-family: var(--font-en); font-size: 12px; font-weight: 600; color: var(--color-orange); letter-spacing: 0.25em; text-transform: uppercase; }
  .section-title { font-family: var(--font-serif); font-size: 32px; font-weight: 700; color: var(--color-charcoal); margin-bottom: 12px; }

  /* 代表挨拶 */
  .message-card { background: var(--color-white); border-radius: var(--radius-lg); border: 1px solid var(--color-gray-light); padding: 48px; display: flex; gap: 48px; align-items: flex-start; }
  .message-avatar { width: 100px; height: 100px; border-radius: 50%; background: var(--color-orange-light); border: 3px solid var(--color-orange); display: flex; align-items: center; justify-content: center; font-size: 44px; line-height: 1; flex-shrink: 0; }
  .message-body { font-size: 15px; color: var(--color-gray); line-height: 1.9; }
  .message-body p + p { margin-top: 16px; }

  /* メンバーカード */
  .member-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 32px; }
  .member-card { background: var(--color-white); border: 1px solid var(--color-gray-light); border-radius: var(--radius-lg); padding: 32px; transition: all 0.25s; }
  .member-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-card); border-color: var(--color-orange); }
  .member-icon { font-size: 40px; margin-bottom: 12px; line-height: 1; }
  .member-role { font-family: var(--font-serif); font-size: 16px; font-weight: 700; color: var(--color-charcoal); margin-bottom: 12px; line-height: 1.4; }
  .member-bio { font-size: 14px; color: var(--color-gray); line-height: 1.8; margin-bottom: 16px; }
  .member-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .member-tag { font-size: 11px; font-weight: 600; color: var(--color-orange); background: var(--color-orange-light); padding: 3px 10px; border-radius: var(--radius-pill); }

  /* 会社情報テーブル */
  .company-table { width: 100%; border-collapse: collapse; }
  .company-table tr { border-bottom: 1px solid var(--color-gray-light); }
  .company-table th { padding: 18px 24px 18px 0; text-align: left; font-size: 13px; font-weight: 700; color: var(--color-charcoal); width: 160px; vertical-align: top; white-space: nowrap; }
  .company-table td { padding: 18px 0; font-size: 15px; color: var(--color-gray); line-height: 1.7; }

  @media (max-width: 768px) {
    .page-hero { padding: 60px 24px; }
    .message-card { flex-direction: column; padding: 32px 24px; gap: 24px; }
    .message-avatar { margin: 0 auto; }
    .member-grid { grid-template-columns: 1fr; }
    .company-table th { width: 100px; font-size: 12px; padding-right: 12px; }
    .company-table td { font-size: 14px; }
  }
</style>

<MainLayout title="わたしたちについて | いるまウェブ製作所" description="いるまウェブ製作所のチーム紹介・代表挨拶・会社情報をご紹介します。専門家チームがあなたのビジネスを本気でサポートします。">

  <!-- ページヘッダー -->
  <div class="page-hero">
    <div style="max-width: 900px; margin: 0 auto; position: relative; z-index: 1;">
      <p class="page-hero-label">ABOUT</p>
      <h1>わたしたちについて</h1>
      <p>専門家チームが、あなたのビジネスを本気でサポートします</p>
    </div>
  </div>

  <!-- 代表挨拶 -->
  <section style="background: var(--color-white); padding: clamp(60px, 8vw, 100px) clamp(20px, 6vw, 80px);">
    <div style="max-width: 860px; margin: 0 auto;">
      <div class="section-label"><span class="section-label-line"></span><span class="section-label-text">MESSAGE</span></div>
      <h2 class="section-title">代表挨拶</h2>
      <div class="message-card">
        <div style="text-align: center; flex-shrink: 0;">
          <div class="message-avatar">🎨</div>
          <p style="margin-top: 12px; font-size: 13px; font-weight: 700; color: var(--color-charcoal);">いるまウェブ製作所 代表</p>
        </div>
        <div class="message-body">
          <p>いるまウェブ製作所は、埼玉県入間市を拠点に活動するWeb制作チームです。<br>システムエンジニア・デザイナー・ネットワークエンジニアという異なる専門性を持つメンバーが集まり、個人事業主・中小企業の皆さまに、大手に負けないクオリティのホームページをリーズナブルな価格でご提供することを使命としています。</p>
          <p>どうぞお気軽にご相談ください。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- チームメンバー -->
  <section style="background: var(--color-cream); padding: clamp(60px, 8vw, 100px) clamp(20px, 6vw, 80px);">
    <div style="max-width: 1000px; margin: 0 auto;">
      <div class="section-label"><span class="section-label-line"></span><span class="section-label-text">TEAM</span></div>
      <h2 class="section-title">チームメンバー</h2>
      <div class="member-grid">
        {members.map(m => (
          <div class="member-card">
            <div class="member-icon">{m.icon}</div>
            <p class="member-role">{m.role}</p>
            <p class="member-bio">{m.bio}</p>
            <div class="member-tags">
              {m.tags.map(tag => <span class="member-tag">{tag}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 会社情報 -->
  <section style="background: var(--color-white); padding: clamp(60px, 8vw, 100px) clamp(20px, 6vw, 80px);">
    <div style="max-width: 720px; margin: 0 auto;">
      <div class="section-label"><span class="section-label-line"></span><span class="section-label-text">COMPANY INFO</span></div>
      <h2 class="section-title">会社情報</h2>
      <table class="company-table" style="margin-top: 32px;">
        <tbody>
          {companyRows.map(([label, value]) => (
            <tr>
              <th>{label}</th>
              <td>
                {label === "電話番号"
                  ? <a href={`tel:${value.replace(/-/g, '')}`} style="color: var(--color-orange); text-decoration: none;">{value}</a>
                  : value
                }
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: var(--color-cream); padding: clamp(60px, 8vw, 100px) clamp(20px, 6vw, 80px); text-align: center;">
    <div style="max-width: 640px; margin: 0 auto;">
      <h2 style="font-family: var(--font-serif); font-size: clamp(24px, 3vw, 36px); font-weight: 700; color: var(--color-charcoal); margin-bottom: 16px;">まずはお気軽にご相談ください</h2>
      <p style="color: var(--color-gray); font-size: 15px; margin-bottom: 40px; line-height: 1.9;">ご相談・お見積もりは無料です。お気軽にどうぞ。</p>
      <a href="/contact" style="display: inline-flex; align-items: center; gap: 8px; background: var(--color-orange); color: var(--color-white); font-weight: 600; padding: 18px 48px; border-radius: var(--radius-pill); text-decoration: none; font-size: 17px; box-shadow: var(--shadow-md); transition: all 0.25s;" onmouseover="this.style.background='var(--color-orange-deep)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='var(--color-orange)';this.style.transform='none'">
        無料相談はこちら →
      </a>
    </div>
  </section>

</MainLayout>
