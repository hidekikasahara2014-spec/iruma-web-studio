---
import MainLayout from '../layouts/MainLayout.astro';
import { site } from '../config/site';
---
<style>
  .page-hero { background: var(--color-charcoal); color: var(--color-cream); padding: 80px 80px 72px; position: relative; overflow: hidden; }
  .page-hero::after { content: ''; position: absolute; top: -60px; right: -60px; width: 300px; height: 300px; background: radial-gradient(circle, var(--color-orange-tint) 0%, transparent 70%); border-radius: 50%; opacity: 0.15; pointer-events: none; }
  .page-hero-label { font-family: var(--font-en); font-size: 12px; font-weight: 600; color: var(--color-orange); letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 16px; display: flex; align-items: center; gap: 12px; }
  .page-hero-label::before { content: ''; width: 32px; height: 1px; background: var(--color-orange); }
  .page-hero h1 { font-family: var(--font-serif); font-size: clamp(28px, 3.5vw, 48px); font-weight: 700; margin-bottom: 12px; color: var(--color-cream); }
  .page-hero p { font-size: 16px; color: var(--color-gray-light); }

  /* 修正: TASK1 - メールのみのシンプルな連絡ページに変更 */
  .contact-email-card {
    background: var(--color-white);
    border: 2px solid var(--color-orange);
    border-radius: var(--radius-lg);
    padding: 56px 48px;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .method-icon {
    width: 72px; height: 72px; background: var(--color-orange-light);
    border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;
    margin: 0 auto 24px; color: var(--color-orange);
  }
  .method-label { font-family: var(--font-serif); font-size: 20px; font-weight: 700; color: var(--color-charcoal); margin-bottom: 8px; }
  .method-value { font-size: 18px; font-weight: 700; color: var(--color-orange); margin-bottom: 6px; }
  .method-note { font-size: 13px; color: var(--color-gray); margin-bottom: 36px; }
  .mailto-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--color-orange); color: var(--color-white);
    font-weight: 700; padding: 18px 48px;
    border-radius: var(--radius-pill); text-decoration: none;
    font-size: 16px; box-shadow: var(--shadow-md); transition: all 0.25s;
  }
  .mailto-btn:hover { background: var(--color-orange-deep); transform: translateY(-2px); }

  @media (max-width: 768px) {
    .page-hero { padding: 60px 24px; }
    .contact-email-card { padding: 40px 24px; }
  }
</style>

<MainLayout title="お問い合わせ" description="ご相談・お見積もりはメールにてお気軽にどうぞ。">

  <div class="page-hero">
    <div style="max-width: 900px; margin: 0 auto; position: relative; z-index: 1;">
      <p class="page-hero-label">CONTACT</p>
      <h1>お問い合わせ</h1>
      <p>ご相談・お見積もりは無料です。メールにてお気軽にどうぞ。</p>
    </div>
  </div>

  <section style="background: var(--color-white); padding: 100px 80px;">
    <div style="max-width: 900px; margin: 0 auto;">

      <!-- 修正: TASK1 - 電話・LINE・フォーム削除、メールのみに統一 -->
      <div class="contact-email-card">
        <div class="method-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <p class="method-label">メールでのご相談</p>
        <p class="method-value">{site.email}</p>
        <p class="method-note">24時間受付・2営業日以内に返信いたします</p>
        <a href={`mailto:${site.email}`} class="mailto-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          メールで相談する →
        </a>
      </div>

      <!-- 補足情報 -->
      <div style="max-width: 560px; margin: 48px auto 0; text-align: center;">
        <p style="font-size: 14px; color: var(--color-gray); line-height: 1.9;">
          ご相談の際は、現在の状況・ご要望・おおよそのご予算を<br>
          お書き添えいただけるとスムーズです。
        </p>
      </div>

    </div>
  </section>

</MainLayout>
