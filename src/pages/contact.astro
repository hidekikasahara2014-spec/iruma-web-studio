---
import MainLayout from '../layouts/MainLayout.astro';
import { site } from '../config/site';
---
<MainLayout title="お問い合わせ" description="ご相談・お見積もりは無料です。お気軽にお問い合わせください。">

  <div class="bg-gradient-to-r from-blue-900 to-blue-700 text-white py-14 px-4 text-center">
    <h1 class="text-3xl md:text-4xl font-black mb-3">お問い合わせ</h1>
    <p class="text-blue-200">ご相談・お見積もりは無料です。お気軽にどうぞ。</p>
  </div>

  <section class="py-16 px-4 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        <!-- 連絡手段 -->
        {[
          { icon: "📞", label: "お電話", value: site.tel, note: "平日 9:00〜18:00" },
          { icon: "✉️", label: "メール", value: site.email, note: "24時間受付・2営業日以内に返信" },
          { icon: "💬", label: "LINE", value: "LINE公式アカウント", note: "お気軽にメッセージください" },
        ].map(({ icon, label, value, note }) => (
          <div class="text-center bg-gray-50 rounded-xl p-6 border border-gray-200">
            <p class="text-4xl mb-3">{icon}</p>
            <p class="font-bold text-gray-800 mb-1">{label}</p>
            <p class="text-blue-900 font-medium text-sm mb-1">{value}</p>
            <p class="text-xs text-gray-500">{note}</p>
          </div>
        ))}
      </div>

      <!-- フォーム -->
      <div class="bg-gray-50 rounded-2xl p-8 border border-gray-200">
        <h2 class="text-xl font-black text-gray-800 mb-6">お問い合わせフォーム</h2>
        <form action={site.formEndpoint} method="POST" class="space-y-5">

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">
                お名前 <span class="text-red-500">*</span>
              </label>
              <input type="text" name="name" required
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500"
                placeholder="山田 太郎" />
            </div>
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">会社名・屋号</label>
              <input type="text" name="company"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500"
                placeholder="〇〇食堂" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">
                業種 <span class="text-red-500">*</span>
              </label>
              <select name="industry" required
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500 bg-white">
                <option value="">選択してください</option>
                <option>飲食店・カフェ</option>
                <option>美容室・理容室</option>
                <option>整体・接骨院</option>
                <option>工務店・リフォーム</option>
                <option>自動車整備工場</option>
                <option>学習塾</option>
                <option>歯科医院</option>
                <option>その他</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">ご興味のあるプラン</label>
              <select name="plan"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500 bg-white">
                <option>まだ未定</option>
                <option>Starterプラン（5万円〜）</option>
                <option>Standardプラン（10万円〜）</option>
                <option>Professionalプラン（30万円〜）</option>
                <option>保守プランのみ</option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">
                メールアドレス <span class="text-red-500">*</span>
              </label>
              <input type="email" name="email" required
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500"
                placeholder="example@email.com" />
            </div>
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">電話番号</label>
              <input type="tel" name="tel"
                class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500"
                placeholder="090-0000-0000" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">
              お問い合わせ内容 <span class="text-red-500">*</span>
            </label>
            <textarea name="message" required rows="5"
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:border-blue-500 resize-none"
              placeholder="現在の状況やご要望をできる範囲でお書きください。（例：飲食店を経営していますが、ホームページがなく困っています。予算は〇万円程度を考えています。）"></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input type="checkbox" id="privacy" name="privacy" required class="mt-1" />
            <label for="privacy" class="text-sm text-gray-700">
              <a href="/privacy" class="text-blue-700 hover:underline" target="_blank">プライバシーポリシー</a>に同意します
              <span class="text-red-500">*</span>
            </label>
          </div>

          <button type="submit"
            class="w-full bg-orange-400 text-white font-black py-4 rounded-xl hover:bg-orange-500 transition-colors text-lg shadow-md">
            送信する →
          </button>
          <p class="text-xs text-gray-500 text-center">通常2営業日以内にご返答します</p>
        </form>
      </div>
    </div>
  </section>

</MainLayout>
