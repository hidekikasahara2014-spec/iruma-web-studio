---
import MainLayout from '../layouts/MainLayout.astro';
import { site } from '../config/site';
---
<style>
  .page-hero { background: var(--color-charcoal); color: var(--color-cream); padding: 80px 80px 72px; position: relative; overflow: hidden; }
  .page-hero::after { content: ''; position: absolute; top: -60px; right: -60px; width: 300px; height: 300px; background: radial-gradient(circle, var(--color-orange-tint) 0%, transparent 70%); border-radius: 50%; opacity: 0.15; pointer-events: none; }
  .page-hero-label { font-family: var(--font-en); font-size: 12px; font-weight: 600; color: var(--color-orange); letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 16px; display: flex; align-items: center; gap: 12px; }
  .page-hero-label::before { content: ''; width: 32px; height: 1px; background: var(--color-orange); }
  .page-hero h1 { font-family: var(--font-serif); font-size: clamp(28px, 3.5vw, 48px); font-weight: 700; margin-bottom: 12px; color: var(--color-cream); }
  .page-hero p { font-size: 16px; color: var(--color-gray-light); }

  .contact-method {
    background: var(--color-white); border: 1px solid var(--color-gray-light);
    border-radius: var(--radius-lg); padding: 32px 24px; text-align: center;
    transition: all 0.3s;
  }
  .contact-method:hover { transform: translateY(-4px); box-shadow: var(--shadow-card); }
  .method-icon {
    width: 56px; height: 56px; background: var(--color-orange-light);
    border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center;
    margin: 0 auto 16px; color: var(--color-orange); transition: all 0.3s;
  }
  .contact-method:hover .method-icon { background: var(--color-orange); color: var(--color-white); }
  .method-label { font-family: var(--font-serif); font-size: 16px; font-weight: 700; color: var(--color-charcoal); margin-bottom: 6px; }
  .method-value { font-size: 14px; font-weight: 600; color: var(--color-orange); margin-bottom: 4px; }
  .method-note { font-size: 12px; color: var(--color-gray); }

  .form-label { display: block; font-size: 13px; font-weight: 600; color: var(--color-charcoal); margin-bottom: 6px; font-family: var(--font-en); letter-spacing: 0.03em; }
  .form-required { color: var(--color-orange); margin-left: 4px; }
  .form-input {
    width: 100%; border: 1.5px solid var(--color-gray-light); border-radius: var(--radius-md);
    padding: 12px 16px; font-size: 14px; color: var(--color-charcoal);
    background: var(--color-white); transition: border-color 0.2s; outline: none;
    font-family: var(--font-sans);
  }
  .form-input:focus { border-color: var(--color-orange); }
  .form-input::placeholder { color: var(--color-gray); }

  @media (max-width: 768px) {
    .page-hero { padding: 60px 24px; }
  }
</style>

<MainLayout title="お問い合わせ" description="ご相談・お見積もりは無料です。お気軽にお問い合わせください。">

  <div class="page-hero">
    <div style="max-width: 900px; margin: 0 auto; position: relative; z-index: 1;">
      <p class="page-hero-label">CONTACT</p>
      <h1>お問い合わせ</h1>
      <p>ご相談・お見積もりは無料です。お気軽にどうぞ。</p>
    </div>
  </div>

  <section style="background: var(--color-white); padding: 100px 80px;">
    <div style="max-width: 900px; margin: 0 auto;">

      <!-- 連絡手段 -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" style="margin-bottom: 64px;">
        {[
          {
            label: "お電話", value: site.tel, note: "平日 9:00〜18:00",
            svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.68A2 2 0 012 .11h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>`
          },
          {
            label: "メール", value: site.email, note: "24時間受付・2営業日以内に返信",
            svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4H20C21.1 4 22 4.9 22 6V18C22 19.1 21.1 20 20 20H4C2.9 20 2 19.1 2 18V6C2 4.9 2.9 4 4 4Z"/><polyline points="22,6 12,13 2,6"/></svg>`
          },
          {
            label: "LINE", value: "LINE公式アカウント", note: "お気軽にメッセージください",
            svg: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`
          },
        ].map(({ label, value, note, svg }) => (
          <div class="contact-method">
            <div class="method-icon" set:html={svg}></div>
            <p class="method-label">{label}</p>
            <p class="method-value">{value}</p>
            <p class="method-note">{note}</p>
          </div>
        ))}
      </div>

      <!-- フォーム -->
      <div style="background: var(--color-cream); border-radius: var(--radius-lg); padding: 48px;">
        <h2 style="font-family: var(--font-serif); font-size: 24px; font-weight: 700; color: var(--color-charcoal); margin-bottom: 32px;">お問い合わせフォーム</h2>
        <form action={site.formEndpoint} method="POST" style="display: flex; flex-direction: column; gap: 20px;">

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="form-label">
                お名前<span class="form-required">*</span>
              </label>
              <input type="text" name="name" required class="form-input" placeholder="山田 太郎" />
            </div>
            <div>
              <label class="form-label">会社名・屋号</label>
              <input type="text" name="company" class="form-input" placeholder="〇〇食堂" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="form-label">業種<span class="form-required">*</span></label>
              <select name="industry" required class="form-input" style="background: var(--color-white);">
                <option value="">選択してください</option>
                <option>飲食店・カフェ</option>
                <option>美容室・理容室</option>
                <option>整体・接骨院</option>
                <option>工務店・リフォーム</option>
                <option>自動車整備工場</option>
                <option>学習塾</option>
                <option>歯科医院</option>
                <option>その他</option>
              </select>
            </div>
            <div>
              <label class="form-label">ご興味のあるプラン</label>
              <select name="plan" class="form-input" style="background: var(--color-white);">
                <option>まだ未定</option>
                <option>Starterプラン（5万円〜）</option>
                <option>Standardプラン（10万円〜）</option>
                <option>Professionalプラン（30万円〜）</option>
                <option>保守プランのみ</option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
              <label class="form-label">メールアドレス<span class="form-required">*</span></label>
              <input type="email" name="email" required class="form-input" placeholder="example@email.com" />
            </div>
            <div>
              <label class="form-label">電話番号</label>
              <input type="tel" name="tel" class="form-input" placeholder="090-0000-0000" />
            </div>
          </div>

          <div>
            <label class="form-label">お問い合わせ内容<span class="form-required">*</span></label>
            <textarea name="message" required rows="5" class="form-input" style="resize: none;" placeholder="現在の状況やご要望をできる範囲でお書きください。（例：飲食店を経営していますが、ホームページがなく困っています。予算は〇万円程度を考えています。）"></textarea>
          </div>

          <div style="display: flex; align-items: flex-start; gap: 12px;">
            <input type="checkbox" id="privacy" name="privacy" required style="margin-top: 3px; accent-color: var(--color-orange);" />
            <label for="privacy" style="font-size: 13px; color: var(--color-gray);">
              <a href="/privacy" style="color: var(--color-orange); text-decoration: underline;" target="_blank">プライバシーポリシー</a>に同意します<span class="form-required">*</span>
            </label>
          </div>

          <button type="submit" style="width: 100%; background: var(--color-orange); color: var(--color-white); font-weight: 700; padding: 18px; border-radius: var(--radius-pill); border: none; font-size: 16px; cursor: pointer; transition: all 0.25s; box-shadow: var(--shadow-md);" onmouseover="this.style.background='var(--color-orange-deep)';this.style.transform='translateY(-2px)'" onmouseout="this.style.background='var(--color-orange)';this.style.transform='none'">
            送信する →
          </button>
          <p style="font-size: 12px; color: var(--color-gray); text-align: center;">通常2営業日以内にご返答します</p>
        </form>
      </div>
    </div>
  </section>

</MainLayout>
