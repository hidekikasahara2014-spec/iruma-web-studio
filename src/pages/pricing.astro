---
import MainLayout from '../layouts/MainLayout.astro';
import PricingCard from '../components/PricingCard.astro';
import FAQ from '../components/FAQ.astro';

const maintenancePlans = [
  { name: "Light", price: "3,300円/月", features: ["サーバー・ドメイン・SSL管理", "軽微な文言修正（月1回まで）", "障害時の一次対応"] },
  { name: "Basic", price: "8,800円/月", features: ["Lightの内容すべて", "月1回の更新作業（画像差し替え等）", "月次アクセスレポート"] },
  { name: "Pro", price: "22,000円〜/月", features: ["Basicの内容すべて", "SEO継続施策", "コンテンツ更新月3回まで", "月次戦略相談（30分）"] },
];

const faqItems = [
  { q: "ドメイン代・サーバー代は別途必要ですか？", a: "はい。ドメイン（年間約1,000〜3,000円）とサーバー（月額約500〜1,500円）は別途お客様のご負担となります。設定・移管のサポートは全プラン無料です。" },
  { q: "途中でプラン変更できますか？", a: "はい、可能です。制作途中でのアップグレードは差額精算でご対応します。ダウングレードは内容の調整が必要な場合がございますのでご相談ください。" },
  { q: "解約手数料はありますか？", a: "保守プランの解約手数料はありません。制作プランのキャンセルについては、進捗段階により費用が発生する場合があります。詳細はご相談ください。" },
  { q: "支払い方法は？", a: "銀行振込、クレジットカード（VISA/Mastercard/JCB）に対応しています。制作費は着手金50%・納品時50%の2回払いが基本です。" },
  { q: "領収書・請求書の発行は対応していますか？", a: "もちろん対応しています。インボイス登録番号も記載した適格請求書（インボイス）を発行します。" },
];
---
<MainLayout title="料金プラン" description="5万円〜のシンプル3プランと月額保守プラン。すべて税抜・明朗会計。">

  <div class="bg-gradient-to-r from-blue-900 to-blue-700 text-white py-14 px-4 text-center">
    <h1 class="text-3xl md:text-4xl font-black mb-3">シンプルでわかりやすい3プラン</h1>
    <p class="text-blue-200">すべて税抜価格です。無料相談・お見積もりはお気軽に。</p>
  </div>

  <!-- 制作プラン -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-black text-center text-gray-800 mb-10">制作プラン</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
        <PricingCard
          name="Starterプラン"
          price="50,000円"
          features={[
            "業種別テンプレートから1つ選択",
            "5ページまで（トップ・サービス・概要・フォーム・PP）",
            "お問い合わせフォーム1つ",
            "スマートフォン完全対応",
            "SSL（HTTPS）対応",
            "Google Mapsの埋め込み",
            "ドメイン設定サポート",
            "最短7日納期",
          ]}
          note="カスタムデザイン・ヒアリングなし。チャット確認のみ。"
        />
        <PricingCard
          name="Standardプラン"
          price="100,000円"
          popular={true}
          features={[
            "Starterの内容すべて",
            "初回ヒアリング（対面/オンライン 60分）",
            "10ページまで",
            "色・写真・レイアウトの簡易カスタマイズ",
            "お問い合わせフォーム複数設置可",
            "お客様の声・事例ページ",
            "Google Analytics設置・初期設定",
            "基本SEO設定",
            "2〜3週間納期",
          ]}
          note="中小企業・個人事業主に最適なバランスプラン。"
        />
        <PricingCard
          name="Professionalプラン"
          price="300,000円〜"
          features={[
            "Standardの内容すべて",
            "フルカスタムデザイン（テンプレート非依存）",
            "AIチャットボット標準実装",
            "CMS構築（社内更新可能）",
            "本格SEO対策（構造化データ等）",
            "Google Business Profile最適化",
            "写真・動画コンテンツ制作",
            "月次アクセス解析レポート（3ヶ月）",
            "20ページまで",
            "1〜2ヶ月納期",
          ]}
          note="本気で集客したい方・ブランド刷新向け。"
        />
      </div>

      <!-- オプション -->
      <div class="mt-10 bg-gray-50 rounded-xl p-6">
        <h3 class="font-bold text-gray-800 mb-4">Professionalプランのオプション例</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm text-gray-700">
          {[
            ["多言語対応（英語+1言語）", "+100,000円"],
            ["ECショップ機能", "+200,000円〜"],
            ["採用ページ強化", "+50,000円"],
            ["LP制作1本", "+80,000円"],
          ].map(([label, price]) => (
            <div class="bg-white rounded-lg p-4 border border-gray-200">
              <p class="font-medium mb-1">{label}</p>
              <p class="text-blue-900 font-bold">{price}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 保守プラン -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-black text-center text-gray-800 mb-3">保守プラン（月額）</h2>
      <p class="text-center text-gray-500 mb-10">制作後も安心のサポート。制作プランと同時にご契約ください。</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {maintenancePlans.map(p => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
            <p class="font-black text-lg text-gray-800 mb-1">{p.name}</p>
            <p class="text-2xl font-bold text-blue-900 mb-4">{p.price}</p>
            <ul class="space-y-2">
              {p.features.map(f => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <span class="text-green-500 font-bold mt-0.5">✓</span>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-black text-center text-gray-800 mb-10">料金についてよくある質問</h2>
      <FAQ items={faqItems} />
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-blue-900 text-white py-14 px-4 text-center">
    <h2 class="text-2xl font-black mb-4">まずは無料相談から</h2>
    <p class="text-blue-200 mb-8">ご予算・ご要望をお聞きして、最適なプランをご提案します。</p>
    <a href="/contact" class="inline-block bg-orange-400 text-white font-black px-10 py-5 rounded-xl hover:bg-orange-500 transition-colors text-xl shadow-lg">
      無料相談を申し込む →
    </a>
  </section>

</MainLayout>
