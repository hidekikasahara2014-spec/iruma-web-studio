---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  industry: string;
}
const { title, description = title, industry } = Astro.props;
---
<style>
  .sample-annotation {
    background: var(--color-charcoal);
    color: var(--color-cream);
    padding: 12px 48px;
    font-size: 13px;
    text-align: center;
    letter-spacing: 0.04em;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .sample-annotation a {
    color: var(--color-orange);
    text-decoration: none;
    font-weight: 600;
    margin-left: 16px;
    transition: opacity 0.2s;
  }
  .sample-annotation a:hover { opacity: 0.8; }
  .sample-cta-footer {
    background: var(--color-charcoal);
    color: var(--color-cream);
    padding: 80px 48px;
    text-align: center;
  }
  .sample-cta-title {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .sample-cta-sub {
    font-size: 14px;
    color: var(--color-gray-light);
    margin-bottom: 36px;
    font-family: var(--font-en);
    letter-spacing: 0.05em;
  }
  .sample-cta-btns {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .sample-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-orange);
    color: var(--color-white);
    font-weight: 600;
    padding: 16px 36px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    font-size: 15px;
    transition: all 0.25s;
  }
  .sample-btn-primary:hover {
    background: var(--color-orange-deep);
    transform: translateY(-2px);
  }
  .sample-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1.5px solid rgba(255,255,255,0.4);
    color: var(--color-cream);
    font-weight: 600;
    padding: 16px 36px;
    border-radius: var(--radius-pill);
    text-decoration: none;
    font-size: 15px;
    transition: all 0.25s;
  }
  .sample-btn-secondary:hover {
    background: rgba(255,255,255,0.1);
  }
  @media (max-width: 768px) {
    .sample-annotation { padding: 12px 16px; font-size: 12px; }
    .sample-cta-footer { padding: 60px 24px; }
    .sample-cta-title { font-size: 24px; }
  }
</style>

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- 修正: TASK5 - Shippori Mincho除去、Noto Sans JPに統一 -->
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="min-h-screen flex flex-col">

  <div class="sample-annotation">
    これは<strong>サンプルサイト</strong>です。架空の事業者として作成しています。
    <a href="/samples">サンプル一覧 →</a>
    <a href="/">制作会社サイトへ →</a>
  </div>

  <main class="flex-1">
    <slot />
  </main>

  <div class="sample-cta-footer">
    <p class="sample-cta-title">
      このようなホームページを<span style="color: var(--color-orange);">5万円〜</span>で制作できます
    </p>
    <p class="sample-cta-sub">合同会社LOTUS — SE × デザイナー × 生成AI</p>
    <div class="sample-cta-btns">
      <a href="/pricing" class="sample-btn-primary">料金プランを見る →</a>
      <a href="/contact" class="sample-btn-secondary">無料相談・お問い合わせ</a>
    </div>
  </div>
</body>
</html>
